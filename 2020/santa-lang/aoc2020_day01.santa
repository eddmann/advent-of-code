input: read("aoc://2020/1")

let parse = lines >> map(int)

part_one: {
  parse(input)
    |> combinations(2)
    |> find(|pair| sum(pair) == 2020)
    |> reduce(*)
}

part_two: {
  parse(input)
    |> combinations(3)
    |> find(|trio| sum(trio) == 2020)
    |> reduce(*)
}

