// Generated by santa-agent from TypeScript solution

input: read("aoc://2015/12")

let sum_no_red = |text| {
  let chars = list(text)
  let n = size(chars)
  let mut i = 0

  let mut parse_value = || 0

  let parse_string = || {
    i = i + 1
    let start = i
    0.. |> each |_| {
      match chars[i] {
        "\\" { i = i + 2 }
        "\"" {
          break nil
        }
        _ { i = i + 1 }
      }
    }
    let result = text[start..i]
    i = i + 1;

    result
  }

  let parse_number = || {
    let start = i
    if chars[i] == "-" { i = i + 1 }
    0.. |> each |_| {
      if i < n && chars[i] >= "0" && chars[i] <= "9" {
        i = i + 1
      } else {
        break nil
      }
    };

    int(text[start..i])
  }

  let parse_array = || {
    i = i + 1
    let mut total = 0
    if chars[i] != "]" {
      total = total + parse_value();

      0.. |> each |_| {
        if chars[i] == "," {
          i = i + 1;

          total = total + parse_value()
        } else {
          break nil
        }
      }
    }
    i = i + 1;

    total
  }

  let parse_object = || {
    i = i + 1
    let mut total = 0
    let mut has_red = false
    let parse_pair = || {
      parse_string()
      i = i + 1;

      if chars[i] == "\"" {
        let val = parse_string();

        if val == "red" { has_red = true }
      } else {
        total = total + parse_value()
      }
    }
    if chars[i] != "}" {
      parse_pair();

      0.. |> each |_| {
        if chars[i] == "," {
          i = i + 1;

          parse_pair()
        } else {
          break nil
        }
      }
    }
    i = i + 1;

    if has_red { 0 } else { total }
  }

  parse_value = || match chars[i] {
    "\"" {
      parse_string();

      0
    }
    "[" { parse_array() }
    "{" { parse_object() }
    _ { parse_number() }
  };

  parse_value()
}

part_one: {
  ints(input) |> sum
}

part_two: {
  sum_no_red(input)
}

test: {
  input: "[1,2,3]"
  part_one: 6
  part_two: 6
}

