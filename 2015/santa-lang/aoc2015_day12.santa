  input: "{\"a\":{\"b\":4},\"c\":-1}"
  part_one: 3
  part_two: 3
}

test: {
  input: "[1,{\"c\":\"red\",\"b\":2},3]"
  part_one: 6
  part_two: 4
}

test: {
  input: "{\"d\":\"red\",\"e\":[1,2,3,4],\"f\":5}"
  part_one: 15
  part_two: 0
}

test: {
  input: "[1,\"red\",5]"
  part_one: 6
  part_two: 6
}

