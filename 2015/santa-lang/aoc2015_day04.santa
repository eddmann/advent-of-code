input: read("aoc://2015/4")

let find_nonce = |key, zeros| {
  let prefix = "0" * zeros;

  1.. |> find(|n| md5(key + n)[0..zeros] == prefix)
}

part_one: {
  find_nonce(input, 5)
}

part_two: {
  find_nonce(input, 6)
}

